# ──────────────────────────────────────────────────────────
# Cabs frontend (Vite) — environment variables
# ──────────────────────────────────────────────────────────
# Copy to .env.local (gitignored) for local dev overrides.
# Set these on your hosting platform for production.
# Only VITE_* prefixed vars are exposed to the client bundle.

# ── Brand / SEO ───────────────────────────────────────────
# Used in canonical URLs, OG tags, JSON-LD, mailto fallbacks.
VITE_SITE_URL=https://www.joincabs.com
VITE_PUBLIC_EMAIL=hello@joincabs.com

# ── API ───────────────────────────────────────────────────
# Empty = use relative URLs (Vite proxy in dev, same-origin reverse
# proxy in prod). Set this if your backend is on a different origin
# in production (e.g. https://api.joincabs.com).
VITE_API_URL=

# ── Mock fallback ─────────────────────────────────────────
# Set to "true" to use the in-process mock instead of hitting
# the real backend. Useful when working on UI without running
# the server locally. Keep "false" or unset in production.
VITE_USE_MOCK_API=false

# ── Mock testing helper ───────────────────────────────────
# Random failure probability when mocks are on (0..1).
# Useful for testing error UI states.
VITE_MOCK_FAILURE_RATE=0

# ── Cloudflare Turnstile (anti-bot) ───────────────────────
# Public site key — safe to expose in the frontend bundle.
# The matching secret key goes in server/.env (TURNSTILE_SECRET_KEY).
# If unset, the widget is hidden and the backend skips verification.
VITE_TURNSTILE_SITE_KEY=
