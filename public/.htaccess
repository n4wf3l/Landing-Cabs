# =============================================================================
# Cabs - Apache config for Hostinger
# =============================================================================

# -----------------------------------------------------------------------------
# Default charset
# -----------------------------------------------------------------------------
AddDefaultCharset UTF-8

# -----------------------------------------------------------------------------
# MIME types (Hostinger sometimes misses modern ones)
# -----------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType application/javascript            js mjs
  AddType text/css                          css
  AddType image/svg+xml                     svg svgz
  AddType image/webp                        webp
  AddType image/avif                        avif
  AddType application/manifest+json         webmanifest
  AddType application/json                  json map
  AddType font/woff                         woff
  AddType font/woff2                        woff2
  AddType application/wasm                  wasm
</IfModule>

# -----------------------------------------------------------------------------
# Compression
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json application/xml
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml font/woff font/woff2
</IfModule>

# -----------------------------------------------------------------------------
# Cache
#   - /assets/* are content-hashed by Vite -> immutable 1 year
#   - HTML is short-cached so users get the new version quickly
#   - Favicons / images: 30 days
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
  <FilesMatch "\.(js|mjs|css|woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(png|jpe?g|gif|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  <FilesMatch "\.(html|json|xml|txt)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                           "access plus 5 minutes"
  ExpiresByType text/css                            "access plus 1 year"
  ExpiresByType application/javascript              "access plus 1 year"
  ExpiresByType image/png                           "access plus 30 days"
  ExpiresByType image/jpeg                          "access plus 30 days"
  ExpiresByType image/webp                          "access plus 30 days"
  ExpiresByType image/svg+xml                       "access plus 30 days"
  ExpiresByType image/x-icon                        "access plus 30 days"
  ExpiresByType font/woff2                          "access plus 1 year"
</IfModule>

# -----------------------------------------------------------------------------
# Security headers
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# -----------------------------------------------------------------------------
# Rewrites: HTTPS, www canonical, SPA fallback
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !=https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force www (canonical is https://www.joincabs.com/)
  RewriteCond %{HTTP_HOST} ^joincabs\.com$ [NC]
  RewriteRule ^ https://www.joincabs.com%{REQUEST_URI} [L,R=301]

  # SPA fallback: serve existing files/dirs as-is, otherwise hand off to index.html
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Don't rewrite real backend endpoints (PHP, API, etc.)
  RewriteCond %{REQUEST_URI} !^/api/
  RewriteCond %{REQUEST_URI} !\.(php|xml|txt|json|map|js|mjs|css|png|jpe?g|gif|webp|avif|svg|ico|woff2?|ttf|otf|eot|wasm|webmanifest)$ [NC]
  RewriteRule ^ index.html [L]
</IfModule>

# -----------------------------------------------------------------------------
# Block access to sensitive files
# -----------------------------------------------------------------------------
<FilesMatch "(^\.env|^\.git|composer\.(json|lock)|package(-lock)?\.json|\.map$)">
  Require all denied
</FilesMatch>

# -----------------------------------------------------------------------------
# Disable directory listing
# -----------------------------------------------------------------------------
Options -Indexes

# -----------------------------------------------------------------------------
# Custom error -> SPA handles it client-side
# -----------------------------------------------------------------------------
ErrorDocument 404 /index.html
