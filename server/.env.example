# ──────────────────────────────────────────────────────────
# Cabs backend bridge — environment variables
# ──────────────────────────────────────────────────────────
# Copy this file to server/.env (gitignored) for local dev,
# OR set these as platform env vars in production
# (Railway, Render, Fly, Vercel, your VPS, etc.)

# Runtime
NODE_ENV=development
PORT=8080

# CORS origins — comma-separated, no trailing slash
#   Local dev:   http://localhost:5173
#   Vite preview: http://localhost:4173
#   Production:  https://www.joincabs.com,https://joincabs.com
# In production, set NODE_ENV=production and Cabs will auto-default
# to the production origins. Override via this variable if needed.
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:4173

# Branding
BRAND_URL=https://www.joincabs.com

# SMTP (any provider — MailProtect, Postmark, SendGrid, Resend SMTP, etc.)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=info@example.com
MAIL_PASSWORD=replace_me
MAIL_FROM_ADDRESS=info@example.com
MAIL_FROM_NAME=Cabs

# Inbox that receives form submissions (defaults to MAIL_FROM_ADDRESS)
MAIL_INBOUND_TO=info@example.com

# Confirmation email to waitlist subscribers (set "false" to disable)
SEND_NOTIFY_CONFIRMATION=true

# Cloudflare Turnstile — anti-bot verification for /contact and /notify.
# Get the keys from https://dash.cloudflare.com/?to=/:account/turnstile
# The SECRET key MUST stay server-only. The matching SITE key goes in
# the frontend's VITE_TURNSTILE_SITE_KEY (public, OK to expose).
# If left empty, verification is skipped (dev convenience). In production
# you should always set this — the server warns at boot if it's missing.
TURNSTILE_SECRET_KEY=
